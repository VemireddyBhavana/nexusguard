# ─────────────────────────────────────────────────────────────────────────────
# NexusGuard Backend – Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=5000

# AI Provider Keys (at least one is required for AI-powered analysis)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Slack Webhook for autonomous incident notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/HOOK/URL
